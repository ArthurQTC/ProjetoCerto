# Configurações de conexão para o banco de dados AWS RDS PostgreSQL
# Substitua os valores abaixo pelas credenciais da sua instância

# URL de fallback (opcional)
DATABASE_URL=postgresql://usuario:senha@endpoint-antigo.amazonaws.com:5432/postgres?sslmode=require

# URL de Conexão Principal para o NOVO AWS RDS PostgreSQL
DATABASE_URL_RDS=postgresql://usuario:senha@endpoint-novo.amazonaws.com:5432/postgres?sslmode=require

# AWS S3 Configure para Upload de Documentos
AWS_REGION=us-east-2
AWS_S3_BUCKET=seu-bucket-aqui
AWS_ACCESS_KEY_ID=sua-access-key-aqui
AWS_SECRET_ACCESS_KEY=sua-secret-key-aqui

# Chave de API Google Gemini (para integração server-side)
GEMINI_API_KEY=your_gemini_api_key_here
